# ============================================
# .env.example — Render Backend (Server)
# ============================================
# Set these in Render Dashboard > Environment

NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/utbk?sslmode=require
JWT_SECRET=ganti_dengan_string_random_panjang_dan_acak
JWT_EXPIRES_IN=7d

# AI - Multiple API Keys (comma-separated untuk load balancing)
# Format: key1,key2,key3,key4
# Minimal 1 key, recommended 2+ untuk avoid rate limits
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2,your_gemini_api_key_3

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Midtrans Payment Gateway
MIDTRANS_MERCHANT_ID=your_merchant_id
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_IS_PRODUCTION=false
CLIENT_URL=https://stubia.vercel.app

# Cloudinary CDN
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
